# Save as terraform.<AWS_PROFILE>.<workspace>.tfvars — e.g. terraform.rg2k.dev.tfvars
# aws_profile is not set here: scripts/tofu-layer-run.sh exports TF_VAR_aws_profile=$AWS_PROFILE for project.
tf_state_bucket  = "your-tf-state-bucket"
tf_state_key     = "opentofu/project"
tf_state_region  = "us-east-1"
tf_state_encrypt = true

global_identity_workspace    = "global"
global_identity_tf_state_key = "global_identity/secrets"

aws_region     = "us-east-1"
gcp_project_id = "example-project-id"
gcp_region     = "us-central1"

# Networking layer remote state (same bucket layout as scripts/tofu-layer-run.sh). This layer reads subnet and network
# ids from networking outputs when compute_topology.aws.enabled or compute_topology.gcp.enabled is true. Use the same
# tf_state_key prefix as the networking layer. Leave networking_workspace empty to use terraform.workspace so project
# and networking share the same workspace name (e.g. qa).
networking_tf_state_key = "opentofu/networking"
# networking_workspace    = "qa"

# Optional: declarative VMs. Subnet keys must match networking outputs for this region/project:
# aws_networking.subnet_ids / gcp_networking.subnetwork_ids (flattened keys: "<vpc>-<tier>-<subnet_name>").
# The examples below align with network_topology in layers/networking/terraform.tfvars.example (core VPC on us-east-1,
# primary VPC on example-project-id). Set enabled = false if you are not ready to manage instances yet.
compute_topology = {
  aws = {
    enabled = true
    instances = {
      example-web = {
        subnet_key    = "core-public-public-a"
        vpc_name      = "core"
        network_name  = "core"
        private_ip    = "10.0.1.10"
        instance_type = "t3.micro"
        tags = {
          role        = "web"
          environment = "prod"
        }
      }
      example-db = {
        subnet_key    = "core-database-db-a"
        vpc_name      = "core"
        network_name  = "core"
        private_ip    = "10.0.10.10"
        instance_type = "t3.small"
        tags = {
          role        = "database"
          environment = "prod"
        }
      }
    }
  }

  gcp = {
    enabled = true
    instances = {
      example-app = {
        subnet_key     = "primary-database-db-subnet"
        vpc_name       = "primary"
        network_name   = "primary"
        private_ip     = "10.10.10.10"
        machine_type   = "e2-medium"
        zone           = "us-central1-a"
        boot_disk_size_gb = 20
        labels = {
          role        = "app"
          environment = "prod"
        }
      }
    }
  }
}

# Same shape as global_identity; use for project-scoped records only if global_identity already defines some records for this zone (avoid duplicate name+type across layers).
route53_records = {
  "example.com" = [
    {
      name    = "api"
      type    = "A"
      ttl     = 300
      records = ["203.0.113.10"]
    }
  ]
}
