# Save as terraform.<AWS_PROFILE>.<workspace>.tfvars — e.g. terraform.rg2k.dev.tfvars
tf_state_bucket  = "your-tf-state-bucket"
tf_state_key     = "opentofu/networking"
tf_state_region  = "us-east-1"
tf_state_encrypt = true

aws_region     = "us-east-1"
gcp_project_id = "example-project-id"
gcp_region     = "us-central1"

# Optional: declarative VPC layout. This layer applies the entry for `aws_region` under
# `network_topology.aws.regions` and the entry for `gcp_project_id` under
# `network_topology.gcp.projects` (OpenTofu cannot use one module per region/project with
# different providers in a single root module without static provider aliases).
network_topology = {
  aws = {
    enabled = true
    regions = {
      "us-east-1" = {
        vpcs = {
          core = {
            cidr_block = "10.0.0.0/16"
            tags = {
              environment = "prod"
              owner         = "platform"
            }
            subnets = {
              public = [
                {
                  name              = "public-a"
                  cidr_block        = "10.0.1.0/24"
                  availability_zone = "us-east-1a"
                  type              = "public"
                }
              ]
              database = [
                {
                  name              = "db-a"
                  cidr_block        = "10.0.10.0/24"
                  availability_zone = "us-east-1a"
                  type              = "private"
                }
              ]
            }
          }
        }
      }
    }
  }

  gcp = {
    enabled = true
    projects = {
      example-project-id = {
        region = "us-central1"
        vpcs = {
          primary = {
            routing_mode = "GLOBAL"
            subnets = {
              database = [
                {
                  name           = "db-subnet"
                  cidr_block     = "10.10.10.0/24"
                  region         = "us-central1"
                  private_access = true
                }
              ]
            }
          }
        }
      }
    }
  }
}

# Optional: reserved public IPs (separate from network_topology). Same region/project scoping as above.
external_static_ips = {
  aws = {
    enabled = true
    regions = {
      "us-east-1" = {
        elastic_ips = {
          nat-egress = {
            tags = {
              role = "nat"
            }
          }
        }
      }
    }
  }

  gcp = {
    enabled = true
    projects = {
      example-project-id = {
        region = "us-central1"
        regional_external_addresses = {
          api-ingress = {
            region      = "us-central1"
            description = "Regional static IP for forwarding rules / VMs"
          }
        }
        global_external_addresses = {
          https-lb = {
            description = "Global static IP for external HTTPS load balancer"
          }
        }
      }
    }
  }
}
