# Save as terraform.<AWS_PROFILE>.<workspace>.tfvars — e.g. terraform.rg2k.dev.tfvars
tf_state_bucket  = "your-tf-state-bucket"
tf_state_key     = "opentofu/networking"
tf_state_region  = "us-east-1"
tf_state_encrypt = true

aws_region     = "us-east-1"
gcp_project_id = "example-project-id"
gcp_region     = "us-central1"

# Optional: default for IAP SSH firewall rules when network_topology.gcp.enable_iap_ssh_firewall is not set.
# gcp_enable_iap_ssh_firewall = false

# Optional: CIDRs allowed to reach TCP 22 directly (your public IP /32, or 0.0.0.0/0 for open SSH — not recommended in prod).
# Needed for ansible-playbook -i '<vm_public_ip>,'; IAP-only rules do not allow that path. When omitted, use nested key under gcp.
# gcp_ssh_ingress_source_ranges = ["203.0.113.0/24"]

# Optional: default for Cloud NAT when network_topology.gcp.enable_cloud_nat is not set (default true).
# gcp_enable_cloud_nat = false

# Optional: CIDRs allowed to reach DB ports (gcp_db_ingress_ports) on VMs tagged with gcp_db_target_tags.
# Typically the public-subnet CIDR(s) where app VMs live. Empty = no rule created.
# gcp_db_ingress_source_ranges = ["10.10.1.0/24"]

# Optional: TCP ports opened by the db ingress rule. Extend for additional engines (e.g. MySQL 3306, pgBouncer 6432).
# Only evaluated when gcp_db_ingress_source_ranges is non-empty (default: ["5432"]).
# gcp_db_ingress_ports = ["5432"]

# Optional: network tags on DB VMs that receive the db ingress rule (default: ["db"]).
# Must match the tags set on instances in project_data computes.gcp.instances.<name>.tags.
# gcp_db_target_tags = ["db"]

# Optional: CIDRs allowed to reach gcp_web_ingress_ports (HTTP/HTTPS). Use ["0.0.0.0/0"] for public access. Empty = no rule.
# gcp_web_ingress_source_ranges = ["0.0.0.0/0"]

# Optional: TCP ports opened by the web ingress rule (default: ["80", "443"]).
# gcp_web_ingress_ports = ["80", "443"]

# Optional: declarative VPC layout. This layer applies the entry for `aws_region` under
# `network_topology.aws.regions` and the entry for `gcp_project_id` under
# `network_topology.gcp.projects` (OpenTofu cannot use one module per region/project with
# different providers in a single root module without static provider aliases).
network_topology = {
  aws = {
    enabled = true
    regions = {
      "us-east-1" = {
        vpcs = {
          core = {
            cidr_block = "10.0.0.0/16"
            tags = {
              environment = "prod"
              owner         = "platform"
            }
            subnets = {
              public = [
                {
                  name              = "public-a"
                  cidr_block        = "10.0.1.0/24"
                  availability_zone = "us-east-1a"
                  type              = "public"
                }
              ]
              database = [
                {
                  name              = "db-a"
                  cidr_block        = "10.0.10.0/24"
                  availability_zone = "us-east-1a"
                  type              = "private"
                }
              ]
            }
          }
        }
      }
    }
  }

  gcp = {
    enabled = true
    # Optional: per-VPC firewall allowing SSH from IAP (35.235.240.0/20). If omitted, uses gcp_enable_iap_ssh_firewall at the top of this file (default true).
    enable_iap_ssh_firewall = false
    # Optional: CIDRs for direct SSH (tcp/22). Needed for ansible/ssh to the VM public IP; see gcp_ssh_ingress_source_ranges at top.
    # ssh_ingress_source_ranges = ["0.0.0.0/0"]
    # Optional: set false to skip Cloud Router + Cloud NAT (private VMs then need another egress path). If omitted, uses gcp_enable_cloud_nat at top (default true).
    # enable_cloud_nat = false
    # Optional: CIDRs allowed to reach db_ingress_ports on VMs tagged with db_target_tags. Overrides gcp_db_ingress_source_ranges at top.
    # db_ingress_source_ranges = ["10.10.1.0/24"]
    # Optional: TCP ports opened by the db ingress rule. Overrides gcp_db_ingress_ports at top (default ["5432"]).
    # db_ingress_ports = ["5432"]
    # Optional: network tags that identify DB VMs for the db ingress rule. Overrides gcp_db_target_tags at top (default ["db"]).
    # db_target_tags = ["db"]
    # Optional: CIDRs allowed to reach web_ingress_ports (HTTP/HTTPS). Use ["0.0.0.0/0"] for public access. Empty = no rule.
    # web_ingress_source_ranges = ["0.0.0.0/0"]
    # Optional: TCP ports opened by the web ingress rule (default ["80", "443"]).
    # web_ingress_ports = ["80", "443"]
    projects = {
      example-project-id = {
        region = "us-central1"
        vpcs = {
          primary = {
            routing_mode = "GLOBAL"
            subnets = {
              # Public subnet — app VMs with external IPs live here; its CIDR is the db_ingress_source_ranges value.
              public = [
                {
                  name       = "app-subnet"
                  cidr_block = "10.10.1.0/24"
                  region     = "us-central1"
                }
              ]
              # Private subnet — DB VMs live here; no external IPs, egress via Cloud NAT.
              database = [
                {
                  name           = "db-subnet"
                  cidr_block     = "10.10.10.0/24"
                  region         = "us-central1"
                  private_access = true
                }
              ]
            }
          }
        }
      }
    }
  }
}

# Optional: reserved public IPs (separate from network_topology). Same region/project scoping as above.
# IAP / SSH firewall CIDRs belong under network_topology.gcp (or root gcp_* vars), not here — extra keys are ignored.
external_static_ips = {
  aws = {
    enabled = true
    regions = {
      "us-east-1" = {
        elastic_ips = {
          nat-egress = {
            tags = {
              role = "nat"
            }
          }
        }
      }
    }
  }

  gcp = {
    enabled = true
    projects = {
      example-project-id = {
        region = "us-central1"
        regional_external_addresses = {
          api-ingress = {
            region      = "us-central1"
            description = "Regional static IP for forwarding rules / VMs"
          }
        }
        global_external_addresses = {
          https-lb = {
            description = "Global static IP for external HTTPS load balancer"
          }
        }
      }
    }
  }
}
