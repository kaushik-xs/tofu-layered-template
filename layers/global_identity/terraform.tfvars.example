# Save as terraform.<AWS_PROFILE>.<workspace>.tfvars — e.g. terraform.rg2k.dev.tfvars
tf_state_bucket  = "your-tf-state-bucket"
tf_state_key     = "opentofu/global_identity"
tf_state_region  = "us-east-1"
tf_state_encrypt = true

aws_region     = "us-east-1"
gcp_project_id = "example-project-id"
gcp_region     = "us-central1"
github_owner   = "your-org"
github_token   = "set-via-env-or-ci"
vault_address  = "https://vault.example.com"
vault_token    = "set-via-env-or-ci"
route53_hosted_zone_names = [
  "example.com"
]

route53_records = {
  "example.com" = [
    {
      name    = "@"
      type    = "A"
      ttl     = 300
      records = ["203.0.113.10"]
    },
    {
      name    = "www"
      type    = "CNAME"
      records = ["example.com"]
    }
  ]
}